{
  "name": "TradeNote",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "TradeNote App",
      "onAutoForward": "openBrowserOnce"
    }
  },
  "postCreateCommand": "cd /workspace && npm install && npm run build",
  "postStartCommand": "cd /workspace && npm start"
}
